{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Edit",
      "Write",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(wc:*)",
      "Bash(find:*)",
      "Bash(npx add-skill:*)",
      "Bash(mkdir:*)",
      "Bash(touch:*)",
      "Bash(python3:*)",
      "Bash(curl:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(qmd update:*)",
      "Bash(qmd embed:*)",
      "Bash(qmd query:*)",
      "Bash(qmd search:*)",
      "Bash(qmd vsearch:*)",
      "Bash(qmd status:*)",
      "Bash(qmd collection list:*)",
      "WebFetch"
    ],
    "ask": [
      "Bash(git push:*)",
      "Bash(git commit:*)",
      "Bash(gh pr create:*)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(**/secrets/**)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(rm -rf:*)",
      "Bash(npm publish:*)"
    ],
    "defaultMode": "default"
  },
  "enabledMcpjsonServers": ["qmd"]
}
